<%# app/views/posts/index.html.erb — Page d'accueil : liste de tous les potins %>
<%# Cette vue affiche tous les potins publiés par les utilisateurs %>

<%# Titre de l'onglet pour la page d'accueil %>
<% content_for :title, "Derniers Potins — The Big Project" %>

<div class="row">
  <%# ---- En-tête de la page ---- %>
  <div class="col-12 mb-4">
    <div class="d-flex justify-content-between align-items-center">
      <%# Titre principal de la section %>
      <h1 class="h2">🗞️ Derniers Potins</h1>

      <%# Bouton pour créer un nouveau potin — visible uniquement si connecté %>
      <% if logged_in? %>
        <%= link_to "✍️ Nouveau potin", new_post_path, class: "btn btn-dark" %>
      <% end %>
    </div>
    <hr>
  </div>
</div>

<%# Vérifie s'il y a des potins à afficher %>
<% if @posts.empty? %>
  <%# Message affiché si aucun potin n'a été publié %>
  <div class="text-center py-5">
    <p class="text-muted fs-5">Aucun potin pour le moment. Soyez le premier !</p>
    <%# Propose l'inscription si l'utilisateur n'est pas connecté %>
    <% unless logged_in? %>
      <%= link_to "Créer un compte", new_user_path, class: "btn btn-dark mt-2" %>
    <% end %>
  </div>

<% else %>
  <%# ---- Grille de potins : 2 colonnes sur desktop, 1 sur mobile ---- %>
  <div class="row row-cols-1 row-cols-md-2 g-4">
    <%# Boucle sur chaque potin pour l'afficher dans une carte %>
    <% @posts.each do |post| %>
      <div class="col">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <%# Titre du potin avec lien vers la page de détail %>
            <h5 class="card-title">
              <%= link_to post.title, post_path(post), class: "text-decoration-none text-dark" %>
            </h5>

            <%# Extrait du contenu du potin (limité à 200 caractères) %>
            <p class="card-text text-muted">
              <%= truncate(post.content, length: 200) %>
            </p>
          </div>

          <%# Pied de carte avec informations de l'auteur et date de publication %>
          <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
            <%# Auteur : lien vers le profil de l'utilisateur ayant publié le potin %>
            <small>
              Par <%= link_to post.user.name, user_path(post.user), class: "text-decoration-none fw-semibold" %>
            </small>

            <%# Date de publication relative (ex: "il y a 2 heures") %>
            <small class="text-muted">
              <%= time_ago_in_words(post.created_at) %> ago
            </small>
          </div>
        </div>
      </div>
    <% end %>
  </div>

<% end %>
